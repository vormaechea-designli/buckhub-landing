# Buck Hub — environment variable template. Copy to .env and fill in.
# This file IS committed; never put real secrets here.

# PostHog — public project key (starts with phc_). Safe for client-side.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# GitHub — for the feedback widget (creates Issues).
GITHUB_TOKEN=
GITHUB_REPO=

# Slack — incoming webhook URL for notifications.
SLACK_WEBHOOK_URL=
