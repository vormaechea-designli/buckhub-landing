---
// Desktop-only hero layout switcher. Hidden on mobile (Center Stage only there).
---

<div class="variant-switcher" role="group" aria-label="Page layout">
  <button class="variant-btn" data-variant="center" type="button">
    Center Stage
  </button>
  <button class="variant-btn" data-variant="side" type="button">
    Side by Side
  </button>
  <button class="variant-btn" data-variant="split" type="button">Split</button>
</div>

<style>
  .variant-switcher {
    display: none; /* shown on desktop only */
    gap: 4px;
    padding: 4px;
    background: var(--pine-soft);
    border-radius: 999px;
  }
  .variant-btn {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-muted);
    background: transparent;
    border: none;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  .variant-btn:hover {
    color: var(--pine);
  }
  .variant-btn[aria-pressed="true"] {
    background: var(--paper);
    color: var(--pine);
    box-shadow: 0 1px 3px rgba(24, 31, 25, 0.12);
  }

  @media (min-width: 900px) {
    .variant-switcher {
      display: inline-flex;
    }
  }
</style>

<script>
  const STORAGE_KEY = "buckhub_variant";
  const VALID = ["center", "side", "split"] as const;
  type Variant = (typeof VALID)[number];

  function apply(variant: Variant, scroll: boolean) {
    document.documentElement.dataset.variant = variant;
    document
      .querySelectorAll<HTMLButtonElement>(".variant-btn")
      .forEach((btn) => {
        btn.setAttribute(
          "aria-pressed",
          btn.dataset.variant === variant ? "true" : "false",
        );
      });
    if (scroll) window.scrollTo({ top: 0, behavior: "smooth" });
  }

  // Restore saved preference (default: center).
  let saved: Variant = "center";
  try {
    const v = localStorage.getItem(STORAGE_KEY);
    if (v && (VALID as readonly string[]).includes(v)) saved = v as Variant;
  } catch {
    /* ignore */
  }
  apply(saved, false);

  document.querySelectorAll<HTMLButtonElement>(".variant-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const variant = btn.dataset.variant as Variant;
      try {
        localStorage.setItem(STORAGE_KEY, variant);
      } catch {
        /* ignore */
      }
      apply(variant, true);
    });
  });
</script>
