---
import Layout from "../layouts/Layout.astro";
import WaitlistForm from "../components/WaitlistForm.astro";

const year = new Date().getFullYear();

const features = [
  {
    n: "01",
    title: "Media that files itself",
    body: "Snap photos and video out in the pasture, dead zone or not — it uploads when you're back in range and ties itself to the right animal. Your camera roll stops drowning.",
  },
  {
    n: "02",
    title: "Free up your phone",
    body: "Every photo and video lives in the app, not eating up your phone storage. One place for it all, off your camera roll and safe.",
  },
  {
    n: "03",
    title: "Share with your partners",
    body: "Send an animal's latest media to your partners in a tap — no group texts, no forwarded clips. Everyone sees the same thing.",
  },
  {
    n: "04",
    title: "Notes on every animal",
    body: "Keep feed, vet, hauling, and training notes right on the animal — not in a notebook in the truck. Always current, always with you.",
  },
];
---

<Layout title="Buck Hub — No Fluff, No Bull.">
  <!-- NAV -->
  <header class="nav">
    <div class="container nav-inner">
      <a href="#top" class="nav-logo" aria-label="Buck Hub home">
        <img
          src="/buck-hub-logo.webp"
          alt="Buck Hub"
          width="76"
          height="46"
        />
      </a>
      <a href="#waitlist" class="btn btn-primary nav-cta">Join the waitlist</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero" id="top">
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow"
          >Early access · Built with working ranchers, owners &amp; partners</span
        >
        <h1>Every bull you train, own or partner on — in one place.</h1>
        <p class="lead">
          Buck Hub brings your animal and your media together in one spot
          without hassle.
        </p>
        <p class="subtitle">
          No more spreadsheets, phone galleries, or a hundred texts a day. Snap
          photos and video in the field — <em>even with no signal</em> — and
          everyone with a stake sees the same info, the moment it happens.
        </p>
      </div>

      <div class="hero-form" id="waitlist">
        <div class="form-card">
          <p class="form-eyebrow">Join the waitlist</p>
          <WaitlistForm instanceId="hero" />
        </div>
      </div>
    </div>
  </section>

  <!-- SHOWCASE -->
  <section class="showcase">
    <div class="container">
      <h2 class="section-title showcase-title">See it in action</h2>
      <p class="showcase-sub">
        Your whole operation — on the laptop at the ranch office, and in your
        pocket out in the field.
      </p>
      <div class="devices">
        <div class="browser">
          <div class="browser-bar" aria-hidden="true">
            <span class="bdot"></span><span class="bdot"></span><span class="bdot"
            ></span>
          </div>
          <img
            src="/buckhub-app-desktop.webp"
            alt="Buck Hub inventory list on desktop"
            width="2000"
            height="1422"
            loading="lazy"
          />
        </div>
        <div class="phone">
          <img
            src="/buckhub-app-phone.webp"
            alt="Buck Hub home screen on a phone"
            width="780"
            height="1688"
            loading="lazy"
          />
        </div>
      </div>

      <div class="platforms">
        <p class="platforms-caption">Coming soon to iPhone &amp; Android</p>
        <div class="store-badges">
          <a
            href="#waitlist"
            class="store-badge"
            aria-label="Buck Hub on the App Store — coming soon"
          >
            <svg class="store-ico" viewBox="0 0 384 512" aria-hidden="true">
              <path
                d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"
              ></path>
            </svg>
            <span class="store-txt"
              ><small>Coming soon to the</small><strong>App Store</strong></span
            >
          </a>
          <a
            href="#waitlist"
            class="store-badge"
            aria-label="Buck Hub on Google Play — coming soon"
          >
            <svg class="store-ico" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.39 12l2.308-2.491zM5.864 2.658L16.802 8.99l-2.303 2.303-8.635-8.635z"
              ></path>
            </svg>
            <span class="store-txt"
              ><small>Coming soon on</small><strong>Google Play</strong></span
            >
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT YOU'LL GET -->
  <section class="features">
    <div class="container">
      <h2 class="section-title">What you'll get</h2>
      <div class="feature-grid">
        {
          features.map((f) => (
            <article class="feature-card">
              <span class="feature-num">{f.n}</span>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="container bottom-inner">
      <div class="bottom-copy">
        <h2>Be first in the chute.</h2>
        <p>
          Join the waitlist and be the first to know when Buck Hub launches. No
          fluff, no bull — just a straighter way to run your animals.
        </p>
      </div>
      <div class="bottom-form">
        <WaitlistForm instanceId="bottom" theme="dark" />
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <img src="/buck-hub-mark.svg" alt="Buck Hub" height="28" />
      <nav class="footer-links">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </nav>
      <p class="footer-meta">© {year} Buck Hub · A Designli project</p>
    </div>
  </footer>
</Layout>

<style>
  /* ---------- NAV ---------- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 250, 249, 0.85);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid rgba(24, 31, 25, 0.08);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 76px;
  }
  .nav-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .nav-logo img {
    height: 52px;
    width: auto;
  }
  .nav-cta {
    padding: 0.7rem 1.15rem;
    flex-shrink: 0;
  }

  /* ---------- HERO (shared) ---------- */
  .hero {
    padding: 4rem 0 5rem;
  }
  .hero-copy .lead {
    font-size: var(--fs-intro);
    font-weight: 600;
    color: var(--pine);
    margin: 1.1rem 0 0;
  }
  .hero-copy .subtitle {
    font-size: var(--fs-intro);
    color: var(--ink);
    margin: 1.25rem 0;
  }
  .hero-copy .subtitle em {
    font-style: italic;
    color: var(--pine);
  }
  .hero-copy h1 {
    font-size: var(--fs-display);
  }
  .form-card {
    background: #fff;
    border: 1px solid rgba(24, 31, 25, 0.08);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.75rem;
  }
  .form-eyebrow {
    font-family: var(--font-serif);
    font-size: var(--fs-card-title);
    font-weight: 700;
    margin-bottom: 1.1rem;
  }

  /* ---------- HERO LAYOUT: Side by Side (copy left, form right) ---------- */
  .hero-inner {
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 900px) {
    .hero-inner {
      grid-template-columns: 1.1fr 0.9fr;
      align-items: center;
      text-align: left;
    }
  }

  /* ---------- SHOWCASE ---------- */
  .showcase {
    padding: 4.5rem 0 5rem;
    background: linear-gradient(180deg, var(--paper), #eef1ec);
  }
  .showcase-title {
    text-align: center;
    margin-bottom: 0.6rem;
  }
  .showcase-sub {
    text-align: center;
    color: var(--ink-muted);
    font-size: var(--fs-intro);
    max-width: 50ch;
    margin: 0 auto 3rem;
  }
  .devices {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }
  .browser {
    flex: 0 1 auto;
    width: min(720px, 64vw);
    min-width: 0;
    background: #fff;
    border: 1px solid rgba(24, 31, 25, 0.1);
    border-radius: 14px;
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .browser-bar {
    height: 36px;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 14px;
    background: #f0efe9;
    border-bottom: 1px solid rgba(24, 31, 25, 0.06);
  }
  .bdot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #cdcabf;
  }
  .browser img {
    display: block;
    width: 100%;
    height: auto;
  }
  .phone {
    flex: 0 0 auto;
    width: clamp(150px, 17vw, 208px);
    margin-left: clamp(-64px, -5vw, -40px);
    margin-bottom: -18px;
    background: var(--ink);
    border-radius: 32px;
    padding: 9px;
    box-shadow: var(--shadow);
    position: relative;
    z-index: 2;
  }
  .phone img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 24px;
  }
  .platforms {
    text-align: center;
    margin-top: 2.75rem;
  }
  .platforms-caption {
    color: var(--ink-muted);
    font-size: var(--fs-small);
    font-weight: 600;
    margin-bottom: 0.9rem;
  }
  .store-badges {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .store-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--ink);
    color: var(--paper);
    padding: 0.55rem 1.1rem;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .store-badge:hover {
    background: var(--pine);
  }
  .store-ico {
    width: 22px;
    height: 22px;
    fill: currentColor;
    flex-shrink: 0;
  }
  .store-txt {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    text-align: left;
  }
  .store-txt small {
    font-size: 0.62rem;
    opacity: 0.85;
  }
  .store-txt strong {
    font-size: 1rem;
    font-weight: 700;
  }

  /* ---------- FEATURES ---------- */
  .features {
    background: linear-gradient(180deg, transparent, var(--pine-soft));
    padding: 4.5rem 0;
  }
  .section-title {
    font-size: var(--fs-section);
    margin-bottom: 2.25rem;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .feature-card {
    background: #fff;
    border: 1px solid rgba(24, 31, 25, 0.08);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--shadow);
  }
  .feature-num {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--sage);
    background: var(--pine);
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 8px;
    display: grid;
    place-items: center;
    margin-bottom: 1rem;
  }
  .feature-card h3 {
    font-size: var(--fs-card-title);
    margin-bottom: 0.6rem;
  }
  .feature-card p {
    color: var(--ink-muted);
    font-size: var(--fs-body);
  }

  /* ---------- BOTTOM CTA ---------- */
  .bottom-cta {
    background: var(--pine);
    color: var(--paper);
    padding: 4.5rem 0;
  }
  .bottom-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 3rem;
    align-items: center;
  }
  .bottom-copy h2 {
    font-size: var(--fs-section);
    color: var(--paper);
    margin-bottom: 1rem;
  }
  .bottom-copy p {
    color: var(--cream);
    font-size: var(--fs-intro);
    max-width: 44ch;
  }
  .bottom-form {
    width: 100%;
    background: var(--pine-mid);
    border: 1px solid rgba(250, 250, 249, 0.15);
    border-radius: var(--radius);
    padding: 1.75rem;
  }

  /* ---------- FOOTER ---------- */
  .footer {
    background: var(--ink);
    color: var(--paper);
    padding: 2rem 0;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer-inner img {
    height: 28px;
    width: auto;
    opacity: 0.9;
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
    font-size: var(--fs-small);
  }
  .footer-links a {
    color: rgba(250, 250, 249, 0.8);
    text-decoration: none;
  }
  .footer-links a:hover {
    color: var(--paper);
  }
  .footer-meta {
    font-size: var(--fs-small);
    color: rgba(250, 250, 249, 0.7);
  }

  /* ---------- MOBILE: force Center Stage everywhere ---------- */
  @media (max-width: 899px) {
    .hero {
      padding: 3rem 0 3.5rem !important;
    }
    .hero .container {
      max-width: var(--maxw) !important;
      padding: 0 24px !important;
    }
    .hero-inner {
      grid-template-columns: 1fr !important;
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
      justify-items: center;
    }
    .hero-copy {
      background: transparent !important;
      color: var(--ink) !important;
      padding: 0 !important;
    }
    .hero-copy .subtitle {
      color: var(--ink) !important;
    }
    .hero-copy .subtitle em {
      color: var(--pine) !important;
    }
    .hero-form {
      width: 100% !important;
      max-width: 460px !important;
      padding: 0 !important;
    }
    .form-card {
      border-width: 1px !important;
      border-color: rgba(24, 31, 25, 0.08) !important;
    }
    .feature-grid {
      grid-template-columns: 1fr;
    }
    .bottom-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .bottom-copy {
      text-align: center;
    }
    .bottom-copy p {
      margin-inline: auto;
    }
    .devices {
      flex-direction: column;
      align-items: center;
    }
    .browser {
      width: 100%;
    }
    .phone {
      margin-left: 0;
      margin-bottom: 0;
      margin-top: -28px;
      width: 172px;
    }
  }

  @media (max-width: 560px) {
    .nav-inner {
      height: 64px;
    }
    .nav-logo img {
      height: 38px;
    }
    .nav-cta {
      padding: 0.6rem 0.9rem;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 520px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
